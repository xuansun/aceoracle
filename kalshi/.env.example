# Kalshi API credentials
# Key ID: the UUID shown in Kalshi dashboard → Settings → API Keys
KALSHI_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path to your RSA private key file (relative to kalshi/ directory)
KALSHI_PRIVATE_KEY_PATH=./kalshi_private.pem

# The Odds API (https://the-odds-api.com) - bookmaker consensus odds
ODDS_API_KEY=your_key_here

# API-Tennis via RapidAPI (https://rapidapi.com/api-tennis/api/api-tennis)
TENNIS_RAPIDAPI_KEY=your_rapidapi_key_here

# Auto-betting (disabled by default — set to true to enable)
AUTO_BET=false
AUTO_BET_EDGE_THRESHOLD=0.08
AUTO_BET_MAX_CONTRACTS=10
